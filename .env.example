# Telegram Bot
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/waifu_bot_db

# Midjourney
MIDJOURNEY_API_KEY=your_midjourney_api_key_here

# Telegram Storage
TELEGRAM_STORAGE_ENABLED=true

# Logging
LOG_LEVEL=INFO
